# Server
PORT=3000

# JWT
JWT_SECRET=your-super-secret-key-change-in-production

# MySQL (Aiven)
MYSQL_HOST=your-host.mysql.aivencloud.com
MYSQL_PORT=13092
MYSQL_USER=your-user
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=your-database

# CORS
ALLOWED_ORIGIN=http://localhost:5173,http://localhost:4200

# Optional: Cloudinary (free tier) image storage
# If set, images are stored in Cloudinary instead of local uploads/
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_FOLDER_PREFIX=samiti
